# Python
__pycache__/
*.pyc
.pytest_cache/

# Virtual Environment
venv/
.venv/

# メディア
fixtures/screenshots/*.png
fixtures/**/*.mp4
# 動画ファイル名にプレイヤーのニックネームが含まれることがあるため、
# 同じファイル名を持つ正解データJSONも動画同様ローカルのみとする
fixtures/videos/*.json
test_frame_ffmpeg.png

# SQLite(実データは含めない方針)
*.db
*.sqlite
*.sqlite3

# 秘匿情報(配信キー等を扱うようになった場合の保険)
.env

# OS由来のゴミファイル(Windows想定)
Thumbs.db
desktop.ini

# エディタ設定
.vscode/
.idea/

# ログ
*.log

# ビルド成果物
dist/
build/
*.egg-info/
