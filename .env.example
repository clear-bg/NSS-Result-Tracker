# このファイルをコピーして .env を作成し、実際の値を設定してください。
# .env はプレイヤー名を含むため .gitignore 対象(git追跡されません)。
# このテンプレート(.env.example)のみ git で追跡します。

# 得点・アシストを記録する対象のプレイヤー名(カンマ区切り)。
# ここに書かれていないプレイヤーが得点者の場合、そのゴールは記録されません。
ALLOWED_PLAYERS=YourName,FriendName

# ゴール/アシストをDBに記録する際、許可リスト(ALLOWED_PLAYERS)をどう扱うか(必須)。
# all: 許可リストに関係なく得点者・アシストを両方そのまま記録する
# allowlist: 得点者・アシストのどちらかが許可リストにいれば、両方そのまま記録する
#            (例: 許可リストに「ブルドッグ」がいて、得点者=たなか・アシスト=ブルドッグなら
#            両方そのまま記録される)
# allowlist_redact: 得点者・アシストのどちらかが許可リストにいれば記録するが、
#                    許可リストに無い方の名前はNULLにする
#                    (例: 上記と同じ状況で、得点者=NULL・アシスト=ブルドッグとして記録される)
GOAL_RECORD_MODE=allowlist

# キャプチャ映像を取得するdshowデバイス名(必須)。通常は"OBS Virtual Camera"のままでよい。
# OBSのバージョン等でデバイス名が異なる場合のみ変更してください。
CAPTURE_DEVICE_NAME=OBS Virtual Camera

# キャプチャ解像度(必須)。OBSの出力解像度と必ず一致させてください(一致しないと映像が壊れます)。
CAPTURE_WIDTH=1920
CAPTURE_HEIGHT=1080

# フレーム取得のタイムアウト秒数(必須)。
# キャプチャ環境によってフレーム取得が詰まりやすい場合に調整してください。
FRAME_READ_TIMEOUT_SECONDS=5.0

# DBファイルの保存先(必須)。
DB_PATH=nss_tracker.db

# ログの詳細度(必須)。DEBUG/INFO/WARNING/ERRORのいずれか。
# トラブルシューティング時にDEBUGへ変更すると詳細なログが出ます。
NSS_TRACKER_LOG_LEVEL=INFO

# 配信画面向けWebダッシュボードのバインド先ホスト・ポート(必須)。
WEB_HOST=127.0.0.1
WEB_PORT=8000
