# このファイルをコピーして .env を作成し、実際の値を設定してください。
# .env はプレイヤー名を含むため .gitignore 対象(git追跡されません)。
# このテンプレート(.env.example)のみ git で追跡します。

# 得点・アシストを記録する対象のプレイヤー名(カンマ区切り)。
# ここに書かれていないプレイヤーが得点者の場合、そのゴールは記録されません。
ALLOWED_PLAYERS=YourName,FriendName

# キャプチャ映像を取得するdshowデバイス名(必須)。通常は"OBS Virtual Camera"のままでよい。
# OBSのバージョン等でデバイス名が異なる場合のみ変更してください。
CAPTURE_DEVICE_NAME=OBS Virtual Camera

# キャプチャ解像度(必須)。OBSの出力解像度と必ず一致させてください(一致しないと映像が壊れます)。
CAPTURE_WIDTH=1920
CAPTURE_HEIGHT=1080
